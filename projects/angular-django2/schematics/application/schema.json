{
  "$schema": "http://json-schema.org/schema",
  "$id": "AngularDjango2Application",
  "title": "angular-django2 application schematic",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "description": "The application name."
    },
    "routing": {
      "type": "boolean",
      "default": true
    },
    "standalone": {
      "type": "boolean",
      "default": true
    },
    "ssr": {
      "type": "boolean",
      "description": "Configure the application for Server-Side Rendering (SSR) and Static Site Generation (SSG/Prerendering). Defaults to false.",
      "default": false
    },
    "zoneless": {
      "type": "boolean",
      "description": "Generate an application that does not use zone.js. Defaults to true.",
      "default": true
    },
    "style": {
      "type": "string",
      "default": "scss",
      "description": "The stylesheet format. Defaults to scss."
    }
  },
  "required": ["name"]
}
