{
  "name": "angular-django2",
  "version": "0.1.4",
  "description": "Angular library workspace for Django-friendly integration primitives and custom Angular CLI schematics.",
  "scripts": {
    "ng": "ng",
    "build": "npm run sync:package-metadata && npm run build:library && npm run build:schematics",
    "build:library": "ng build angular-django2",
    "build:schematics": "tsc -p projects/angular-django2/tsconfig.schematics.json && cpy \"*.json\" \"*/schema.json\" \"../../../dist/angular-django2/schematics/\" --cwd=projects/angular-django2/schematics/",
    "build:watch": "npm run sync:package-metadata && ng build angular-django2 --watch --configuration development",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "pack:dry-run": "npm run build && npm pack ./dist/angular-django2 --dry-run",
    "release:prepare": "npm run format:check && npm run lint && npm run test:ci && npm run pack:dry-run",
    "release:version": "node tools/release-version.mjs",
    "sync:package-metadata": "node tools/sync-package-metadata.mjs",
    "test": "ng test --watch=false angular-django2",
    "test:ci": "npm run test:node && ng test angular-django2 --watch=false",
    "cleanup:e2e:tmp-areas": "node --no-warnings --experimental-strip-types tests/utils/temp_areas.ts cleanup",
    "test:node": "vitest run --config vitest.config.mts",
    "test:node:watch": "vitest --config vitest.config.mts",
    "test:e2e": "node --no-warnings --experimental-strip-types tests/utils/temp_areas.ts run",
    "test:e2e:watch": "node --no-warnings --experimental-strip-types tests/utils/temp_areas.ts watch",
    "test:e2e:debug": "node --no-warnings --experimental-strip-types tests/utils/temp_areas.ts debug",
    "generate:api": "ng-openapi-gen"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "license": "MIT",
  "homepage": "https://github.com/shlomoa/angular-django2#readme",
  "bugs": {
    "url": "https://github.com/shlomoa/angular-django2/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shlomoa/angular-django2.git"
  },
  "keywords": [
    "angular",
    "django",
    "csrf",
    "http",
    "library",
    "npm",
    "schematics"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || ^24.0.0",
    "npm": ">=11"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "angular-django2": "file:dist/angular-django2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.6",
    "@angular-devkit/schematics": "^21.2.6",
    "@angular-eslint/builder": "^21.3.1",
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@schematics/angular": "^21.2.6",
    "@types/node": "^25.5.2",
    "angular-eslint": "^21.3.1",
    "cpy-cli": "^7.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "ng-openapi-gen": "^1.0.5",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.8"
  }
}
